listfuzzy <- function(vetor,vetor2){
if(is.vector(vetor)){
returnlist <- list(vetor)
}
if(is.list(vetor) && is.list(vetor2)){
returnlist <- c(vetor, vetor2)
}
if(is.list(vetor) && is.vector(vetor2, mode = "double")){
vetor2 <- list(vetor2)
returnlist <- c(vetor, vetor2)
}
return(returnlist)
}
a <- c(1,22,3,4,5)
b <- c(1,2,3,4,5,6)
c <- c(5,3,4,3,6,6,7)
