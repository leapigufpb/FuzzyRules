listfuzzy <- function(vetor,vetor2){
if(is.vector(vetor)){
returnlist <- list(vetor)
}
if(is.list(vetor) && is.vector(vetor2)){
vetor2 <- list(vetor2)
returnlist <- c(vetor, vetor2)
}
if(is.list(vetor) && is.list(vetor2)){
returnlist <- c(vetor, vetor2)
}
return(returnlist)
}
